{
  "_meta": {
    "purpose": "Worker catalog for delegate — OpenCode Go text models + legacy OpenRouter image/video only.",
    "lastReviewed": "2026-05-20",
    "pricing_units": "USD per 1M tokens (approximate; Go subscription caps apply separately)",
    "orchestrator": "opencode-go/kimi-k2.6 — do NOT delegate back to Kimi for routine work; you are already on Kimi.",
    "notes": "Text model IDs use opencode-go/<model>. Image/video use OpenRouter via /workspace/extra/credentials/openrouter. Persona voice notes use the separate voice-note skill."
  },

  "tasks": {
    "code-cheap":      { "model": "qwen-plus",        "rationale": "fast coding/refactors; different family than orchestrator Kimi" },
    "code-quick":      { "model": "deepseek-flash",   "rationale": "tiny edits, near-zero cost, low latency" },
    "code-frontier":   { "model": "glm-5",            "rationale": "harder multi-step code only when flash/qwen failed — still not Kimi" },
    "summarize":       { "model": "deepseek-pro",     "rationale": "long docs/transcripts — use DeepSeek Pro, NOT Kimi (you are Kimi)" },
    "summarize-fast":  { "model": "deepseek-flash",   "rationale": "short summaries; cheapest" },
    "long-context":    { "model": "deepseek-pro",     "rationale": "multi-doc synthesis with strong reasoning" },
    "doc-synthesis":   { "model": "deepseek-pro",     "rationale": "briefings from large inputs" },
    "reasoning-cheap": { "model": "deepseek-pro",     "rationale": "planning/analysis without burning orchestrator turns" },
    "draft":           { "model": "qwen-plus",        "rationale": "prose drafts for you to review" },
    "translate":       { "model": "qwen-plus",        "rationale": "multilingual; cheap" },
    "extract":         { "model": "deepseek-flash",   "rationale": "structured JSON / classification" },
    "image":           { "model": "nano-banana-pro",  "rationale": "OpenRouter multimodal — default image gen" },
    "image-art":       { "model": "flux-pro",         "rationale": "artistic/stylized images" },
    "image-cheap":     { "model": "flux-klein",       "rationale": "bulk/thumbnail images" },
    "video":           { "model": "veo-3.1",          "rationale": "expensive; confirm with user first" }
  },

  "models": {
    "deepseek-pro": {
      "id": "opencode-go/deepseek-v4-pro",
      "context": 1000000,
      "input_per_mtok": 0.80,
      "output_per_mtok": 3.20,
      "strengths": ["reasoning", "long-context", "doc-synthesis"],
      "use_when": "summaries, multi-doc work, analysis — never use for live chat with the user"
    },
    "deepseek-flash": {
      "id": "opencode-go/deepseek-v4-flash",
      "context": 256000,
      "input_per_mtok": 0.10,
      "output_per_mtok": 0.40,
      "strengths": ["very-fast", "very-cheap", "extract", "quick-edits"],
      "use_when": "default worker for extracts, quick code, fast summaries"
    },
    "qwen-plus": {
      "id": "opencode-go/qwen3.6-plus",
      "context": 1000000,
      "input_per_mtok": 0.50,
      "output_per_mtok": 2.00,
      "strengths": ["code", "drafts", "multilingual"],
      "use_when": "code-cheap, drafting, translation — distinct from Kimi orchestrator"
    },
    "qwen-fast": {
      "id": "opencode-go/qwen3.5-plus",
      "context": 1000000,
      "input_per_mtok": 0.30,
      "output_per_mtok": 1.00,
      "strengths": ["cheapest-general", "fast"],
      "use_when": "when qwen3.6 is overkill"
    },
    "glm-5": {
      "id": "opencode-go/glm-5",
      "context": 200000,
      "input_per_mtok": 0.60,
      "output_per_mtok": 2.40,
      "strengths": ["code-reasoning", "balanced"],
      "use_when": "code-frontier escalation only"
    },
    "minimax": {
      "id": "opencode-go/minimax-m2.7",
      "context": 200000,
      "input_per_mtok": 0.40,
      "output_per_mtok": 1.60,
      "strengths": ["fast-general"],
      "use_when": "alternate cheap worker if qwen/flash struggle"
    },

    "nano-banana-pro": {
      "id": "google/gemini-3-pro-image-preview",
      "type": "image",
      "cost_per_image": 0.08,
      "use_when": "professional images via OpenRouter (legacy file)"
    },
    "flux-pro": {
      "id": "black-forest-labs/flux.2-pro",
      "type": "image",
      "cost_per_image": 0.03,
      "use_when": "artistic images"
    },
    "flux-klein": {
      "id": "black-forest-labs/flux.2-klein-4b",
      "type": "image",
      "cost_per_image": 0.014,
      "use_when": "cheap bulk images"
    },
    "veo-3.1": {
      "id": "google/veo-3.1",
      "type": "video",
      "duration": "4-8s",
      "use_when": "video via OpenRouter — confirm cost with user"
    }
  }
}
