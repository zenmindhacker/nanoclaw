{
  "_meta": {
    "purpose": "Worker catalog for delegate — OpenCode Go text models + legacy OpenRouter image/video only.",
    "lastReviewed": "2026-06-22",
    "pricing_units": "USD per 1M tokens (approximate; Go subscription caps apply separately)",
    "orchestrator": "opencode-go/deepseek-v4-pro",
    "notes": "Orchestrator ID must match OPENCODE_MODEL in host .env. Text model IDs use opencode-go/<model>. Image/video use OpenRouter. Persona voice notes use voice-note skill."
  },

  "tasks": {
    "code-cheap":      { "model": "qwen-plus",        "rationale": "fast coding/refactors; different family than orchestrator" },
    "code-quick":      { "model": "deepseek-flash",   "rationale": "tiny edits, near-zero cost, low latency" },
    "code-frontier":   { "model": "glm-5",            "rationale": "harder multi-step code when flash/qwen failed" },
    "code-agentic":    { "model": "kimi-k2.7",        "rationale": "multi-step agentic coding subagent" },
    "summarize":       { "model": "kimi-k2.7",        "rationale": "long docs/transcripts — 2M ctx Kimi worker" },
    "summarize-fast":  { "model": "deepseek-flash",   "rationale": "short summaries; cheapest" },
    "long-context":    { "model": "kimi-k2.7",        "rationale": "multi-doc synthesis with large context" },
    "doc-synthesis":   { "model": "kimi-k2.7",        "rationale": "briefings from large inputs" },
    "reasoning-cheap": { "model": "deepseek-flash",   "rationale": "light planning without burning orchestrator turns" },
    "reasoning-max":   { "model": "qwen3.7-max",      "rationale": "strategic / peak reasoning — explicit, low frequency" },
    "draft":           { "model": "qwen-plus",        "rationale": "prose drafts for you to review" },
    "translate":       { "model": "qwen-plus",        "rationale": "multilingual; cheap" },
    "extract":         { "model": "deepseek-flash",   "rationale": "structured JSON / classification" },
    "image":           { "model": "nano-banana-pro",  "rationale": "OpenRouter multimodal — default image gen" },
    "image-art":       { "model": "flux-pro",         "rationale": "artistic/stylized images" },
    "image-cheap":     { "model": "flux-klein",       "rationale": "bulk/thumbnail images" },
    "video":           { "model": "veo-3.1",          "rationale": "expensive; confirm with user first" }
  },

  "models": {
    "deepseek-pro": {
      "id": "opencode-go/deepseek-v4-pro",
      "context": 1000000,
      "input_per_mtok": 0.80,
      "output_per_mtok": 3.20,
      "strengths": ["orchestrator", "reasoning", "long-context"],
      "use_when": "orchestrator only — do not delegate to this model"
    },
    "deepseek-flash": {
      "id": "opencode-go/deepseek-v4-flash",
      "context": 256000,
      "input_per_mtok": 0.10,
      "output_per_mtok": 0.40,
      "strengths": ["very-fast", "very-cheap", "extract", "quick-edits"],
      "use_when": "default worker for extracts, quick code, fast summaries"
    },
    "kimi-k2.7": {
      "id": "opencode-go/kimi-k2.7-code",
      "context": 2000000,
      "input_per_mtok": 0.60,
      "output_per_mtok": 2.50,
      "strengths": ["long-context", "code-agentic", "summarize"],
      "use_when": "long transcripts, multi-doc synthesis, agentic code subtasks"
    },
    "qwen3.7-max": {
      "id": "opencode-go/qwen3.7-max",
      "context": 1000000,
      "input_per_mtok": 1.20,
      "output_per_mtok": 4.80,
      "strengths": ["peak-reasoning", "planning"],
      "use_when": "reasoning-max only — tight req/5hr cap on OpenCode Go"
    },
    "qwen-plus": {
      "id": "opencode-go/qwen3.6-plus",
      "context": 1000000,
      "input_per_mtok": 0.50,
      "output_per_mtok": 2.00,
      "strengths": ["code", "drafts", "multilingual"],
      "use_when": "code-cheap, drafting, translation"
    },
    "qwen-fast": {
      "id": "opencode-go/qwen3.7-plus",
      "context": 1000000,
      "input_per_mtok": 0.40,
      "output_per_mtok": 1.60,
      "strengths": ["cheapest-general", "fast"],
      "use_when": "when qwen3.6 is overkill"
    },
    "glm-5": {
      "id": "opencode-go/glm-5.2",
      "context": 200000,
      "input_per_mtok": 0.60,
      "output_per_mtok": 2.40,
      "strengths": ["code-reasoning", "balanced"],
      "use_when": "code-frontier escalation only"
    },
    "minimax-m3": {
      "id": "opencode-go/minimax-m3",
      "context": 1000000,
      "input_per_mtok": 0.45,
      "output_per_mtok": 1.80,
      "strengths": ["fast-general", "multimodal"],
      "use_when": "alternate worker if qwen/flash struggle"
    },
    "minimax": {
      "id": "opencode-go/minimax-m2.7",
      "context": 200000,
      "input_per_mtok": 0.40,
      "output_per_mtok": 1.60,
      "strengths": ["fast-general"],
      "use_when": "legacy alias for minimax-m2.7"
    },

    "nano-banana-pro": {
      "id": "google/gemini-3-pro-image-preview",
      "type": "image",
      "cost_per_image": 0.08,
      "use_when": "professional images via OpenRouter (legacy file)"
    },
    "flux-pro": {
      "id": "black-forest-labs/flux.2-pro",
      "type": "image",
      "cost_per_image": 0.03,
      "use_when": "artistic images"
    },
    "flux-klein": {
      "id": "black-forest-labs/flux.2-klein-4b",
      "type": "image",
      "cost_per_image": 0.014,
      "use_when": "cheap bulk images"
    },
    "veo-3.1": {
      "id": "google/veo-3.1",
      "type": "video",
      "duration": "4-8s",
      "use_when": "video via OpenRouter — confirm cost with user"
    }
  }
}
