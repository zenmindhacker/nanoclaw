    "Overdue": {
      "threshold_percent": 150,
      "description": "100-150% of cadence elapsed"
    },
    "Reconnect": {
      "threshold_percent": null,
      "description": "150%+ of cadence elapsed"
    },
    "On Pause": {
      "threshold_percent": null,
      "description": "Manually paused, skip in digest"
    }
  },
  "matching": {
    "phone_exact": {
      "action": "auto_link",
      "confidence": 1.0
    },
    "name_high": {
      "threshold": 0.95,
      "action": "auto_link"
    },
    "name_medium": {
      "threshold": 0.85,
